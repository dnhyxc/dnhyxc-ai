{
	"compilerOptions": {
		"composite": true,
		"skipLibCheck": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@ui/*": ["./src/components/ui/*"],
			"@design/*": ["./src/components/design/*"]
		}
	},
	"include": ["./apps/frontend/vite.config.ts"]
}
