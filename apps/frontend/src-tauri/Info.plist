<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!--
      macOS 权限说明：无此项时 WKWebView 内 navigator.mediaDevices.getUserMedia 会被系统拒绝。
      修改后需重新执行 tauri build / tauri dev 使合并后的应用包生效。
    -->
    <key>NSMicrophoneUsageDescription</key>
    <string>需要使用麦克风，以便在对话中进行语音输入与识别。</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>需要使用语音识别，以便将语音实时转为文字（与麦克风配合使用）。</string>
    <key>NSAppTransportSecurity</key>
    <dict>
      <!-- Tauri 开发态：uploadCos 等访问 http://localhost API -->
      <key>NSAllowsLocalNetworking</key>
      <true/>
      <!-- 腾讯云 COS 默认 HTTPS 域名一般无需 ATS 明文例外；若使用 HTTP CDN，在此添加 NSExceptionDomains -->
    </dict>
  </dict>
</plist>
