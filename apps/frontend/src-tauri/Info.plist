<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!--
      macOS 权限说明：无此项时 WKWebView 内 navigator.mediaDevices.getUserMedia 会被系统拒绝。
      修改后需重新执行 tauri build / tauri dev 使合并后的应用包生效。
    -->
    <key>NSMicrophoneUsageDescription</key>
    <string>需要使用麦克风，以便在对话中进行语音输入与识别。</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>需要使用语音识别，以便将语音实时转为文字（与麦克风配合使用）。</string>
    <key>NSAppTransportSecurity</key>
    <dict>
      <!--
        macOS ATS（App Transport Security，应用传输安全）默认禁止 http 明文资源。
        生产包中若需要加载特定 http 域名资源，在此添加例外域名（仅放行必要域名，避免全局放开）。
      -->
      <key>NSExceptionDomains</key>
      <dict>
        <key>tdxerr4c5.hd-bkt.clouddn.com</key>
        <dict>
          <key>NSExceptionAllowsInsecureHTTPLoads</key>
          <true/>
          <key>NSIncludesSubdomains</key>
          <true/>
        </dict>
      </dict>
    </dict>
  </dict>
</plist>

