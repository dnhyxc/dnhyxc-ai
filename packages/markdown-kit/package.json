{
	"name": "@dnhyxc-ai/markdown-kit",
	"version": "1.0.1",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": true,
	"files": [
		"dist",
		"README.md"
	],
	"keywords": [
		"react",
		"markdown",
		"kit",
		"markdown-kit"
	],
	"author": "dnhyxc <dnhyxc@163.com>",
	"license": "MIT",
	"scripts": {
		"clean": "rm -rf dist src/highlight/styles.ts",
		"build:css": "node scripts/build-mk-css.js",
		"build": "pnpm clean && pnpm build:css && tsup",
		"prepack": "pnpm build",
		"pretest": "pnpm build:css",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./styles": {
			"types": "./dist/styles.d.ts",
			"import": "./dist/styles.js",
			"require": "./dist/styles.js"
		},
		"./styles/*": "./dist/styles/*.css",
		"./styles/*.css": "./dist/styles/*.css",
		"./styles/hljs/*": "./dist/styles/hljs/*",
		"./styles.css": "./dist/styles/markdown-styles.css",
		"./markdown-styles.css": "./dist/styles/markdown-styles.css",
		"./markdown-base.css": "./dist/styles/markdown-base.css",
		"./react": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.js",
			"require": "./dist/react/index.cjs"
		}
	},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"dependencies": {
		"github-markdown-css": "^5.8.1",
		"highlight.js": "^11.11.1",
		"katex": "^0.16.28",
		"markdown-it": "^14.1.0",
		"markdown-it-katex": "^2.0.3",
		"markdown-it-task-lists": "^2.1.1",
		"mermaid": "^11.14.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.0",
		"@types/highlight.js": "^10.1.0",
		"@types/katex": "^0.16.8",
		"@types/markdown-it": "^14.1.2",
		"@types/react": "^19.1.8",
		"happy-dom": "^20.0.10",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tsup": "^8.5.1",
		"vitest": "^3.2.4"
	}
}
