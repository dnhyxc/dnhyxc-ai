{
	"name": "@dnhyxc-ai/release-kit",
	"version": "0.1.1",
	"description": "可配置的桌面端/Tauri 发布辅助 CLI：版本递增、latest.json、GitHub Release 上传、Wiki 文档推送",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"release-kit": "./dist/cli/entry.js"
	},
	"files": [
		"dist",
		"README.md",
		"release-kit.config.example.json"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "pnpm run build"
	},
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"keywords": [
		"tauri",
		"release",
		"github",
		"semver",
		"cli"
	],
	"license": "MIT",
	"dependencies": {
		"dotenv": "^17.2.3"
	},
	"devDependencies": {
		"@types/node": "^22.10.7",
		"typescript": "~5.8.3"
	}
}
